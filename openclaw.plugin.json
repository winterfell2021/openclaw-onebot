{
  "id": "onebot",
  "name": "OneBot Channel",
  "version": "1.2.1",
  "description": "OneBot v11 protocol channel (QQ/Lagrange.Core via WebSocket)",
  "author": "Lagrange.Onebot",
  "channels": ["onebot"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "type": {
        "type": "string",
        "enum": ["forward-websocket", "backward-websocket"],
        "description": "连接类型：正向或反向 WebSocket"
      },
      "host": { "type": "string", "description": "OneBot 主机地址" },
      "port": { "type": "number", "description": "OneBot 端口" },
      "accessToken": { "type": "string", "description": "访问令牌（可选）" },
      "path": { "type": "string", "description": "反向 WS 路径，默认 /onebot/v11/ws" },
      "requireMention": {
        "type": "boolean",
        "default": true,
        "description": "群聊是否必须 @ 机器人才回复"
      },
      "thinkingEmojiEnabled": {
        "type": "boolean",
        "default": false,
        "description": "是否在回复期间给用户消息添加临时表情回应（仅在支持 set_msg_emoji_like 的实现有效）"
      },
      "thinkingEmojiId": {
        "type": "number",
        "default": 60,
        "description": "临时表情 ID（thinkingEmojiEnabled=true 时生效）"
      },
      "qqimgTagEnabled": {
        "type": "boolean",
        "default": true,
        "description": "是否启用 <qqimg>...</qqimg> 图片标签解析"
      },
      "qqimgTagCloseVariants": {
        "type": "array",
        "description": "qqimg 标签允许的闭合形式，如 [\"qqimg\", \"img\"]",
        "items": { "type": "string" },
        "default": ["qqimg", "img"]
      },
      "blockStreaming": {
        "type": "boolean",
        "default": true,
        "description": "是否启用阶段流式发送（true=按思考阶段逐条发送，false=尽量合并后发送）"
      },
      "imageCacheDir": {
        "type": "string",
        "description": "图片缓存目录（建议挂载到 OpenClaw 与 NapCat 共用路径）"
      },
      "groupToolTargetPolicy": {
        "type": "string",
        "enum": ["force-current-group", "respect-target"],
        "default": "force-current-group",
        "description": "群聊上下文中工具调用目标策略：强制当前群或按传入 target"
      },
      "imageFailureFallback": {
        "type": "string",
        "enum": ["none", "upload-file"],
        "default": "upload-file",
        "description": "图片发送失败后的兜底策略"
      },
      "imageFailureFallbackNotice": {
        "type": "boolean",
        "default": false,
        "description": "图片发送失败后转文件上传时，是否额外发送提示文本"
      },
      "groupIncrease": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "message": { "type": "string", "description": "欢迎语模板，{userId} 可替换为新成员 QQ" }
        }
      }
    }
  },
  "uiHints": {
    "accessToken": { "label": "Access Token", "sensitive": true },
    "host": { "label": "主机地址", "placeholder": "127.0.0.1" },
    "port": { "label": "端口", "placeholder": "8080" },
    "requireMention": { "label": "群聊需 @ 回复" },
    "thinkingEmojiEnabled": { "label": "回复中表情提示" },
    "thinkingEmojiId": { "label": "临时表情ID", "placeholder": "60" },
    "qqimgTagEnabled": { "label": "启用<qqimg>标签" },
    "blockStreaming": { "label": "阶段流式发送" },
    "imageCacheDir": { "label": "图片缓存目录", "placeholder": "/data/.openclaw/workspace/.onebot-image-cache" },
    "groupToolTargetPolicy": { "label": "群聊工具目标策略" },
    "imageFailureFallback": { "label": "图片失败兜底策略" },
    "imageFailureFallbackNotice": { "label": "转文件上传提示" }
  }
}
